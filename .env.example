# Google Gemini API Key (used for 'plan' and 'plan-lite' models)
GEMINI_API_KEY=
# DeepSeek API Key (used for 'code' model)
DEEPSEEK_API_KEY=
# Anthropic API Key (used for 'claude' and 'claude-deep' models)
ANTHROPIC_API_KEY=
# Custom master key for authenticating clients with the local LiteLLM proxy
LITELLM_MASTER_KEY=
